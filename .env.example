# Global
PORT=3000
NODE_ENV=development
JWT_SECRET=super_secret_fallback
RS256_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n..."
RS256_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n..."

# Databases
DB_USER=admin
DB_PASSWORD=password
DB_HOST=postgres
DB_PORT=5432

MARKETPLACE_DB=marketplace_db
AI_DB=ai_db
INGESTION_DB=ingestion_db
LOGISTICS_DB=logistics_db
PAYMENT_DB=payment_db

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Service Internal URLs
API_GATEWAY_URL=http://api-gateway:3000
MARKETPLACE_URL=http://marketplace-service:3001
AI_URL=http://ai-service:8000
INGESTION_URL=http://ingestion-service:3002
LOGISTICS_URL=http://logistics-service:3003
PAYMENT_URL=http://payment-service:3004

# External APIs (Placeholders)
COMMODITY_API_KEY=your_commodity_api_key
WEATHER_API_KEY=your_weather_api_key
STRIPE_SECRET_KEY=your_stripe_secret_key
